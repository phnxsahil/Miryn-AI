# Database (Supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional direct Postgres
# WARNING: The default postgres:postgres credentials are for local dev only.
# Always replace them with strong, unique username/password pairs managed via
# your secret store or environment injection before deploying.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/miryn

# Redis
# Example with AUTH enabled: redis://:strongpassword@redis:6379/0
# Configure a password (or TLS) in production and never commit real values.
REDIS_URL=redis://redis:6379

# LLM API
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash-latest
VERTEX_PROJECT_ID=your_project_id_here
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
LLM_PROVIDER=openai

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
SECRET_KEY=generate_random_secret_here
