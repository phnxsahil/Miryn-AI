# Miryn root environment template
# Copy to miryn/.env for local development only. Never commit real secrets.

# ---------------------------------------------------------------------------
# Database configuration (choose ONE backend)
# Local Postgres example with strong credentials (replace username/password!)
DATABASE_URL=postgresql+psycopg2://<DB_USER>:<DB_PASSWORD>@localhost:5432/miryn
# Supabase connection (remove if not using Supabase)
SUPABASE_URL=https://<YOUR_SUPABASE_PROJECT>.supabase.co
SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# ---------------------------------------------------------------------------
# Redis connection (enable AUTH in production)
# Example with password: redis://:strongpassword@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# LLM provider selection. Supported: vertex | openai | anthropic | gemini
LLM_PROVIDER=vertex

# Provider-specific credentials (only fill in those required for your provider)
OPENAI_API_KEY=<OPENAI_API_KEY>
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
GEMINI_API_KEY=<GEMINI_WEB_API_KEY>
GEMINI_MODEL=gemini-1.5-flash-001
VERTEX_PROJECT_ID=<PROJECT_ID_PLACEHOLDER>
VERTEX_LOCATION=us-central1
VERTEX_MODEL=google/gemini-2.0-flash-lite-001
GOOGLE_APPLICATION_CREDENTIALS=<PATH_TO_SERVICE_ACCOUNT_JSON>

# ---------------------------------------------------------------------------
# App URLs and secrets
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
SECRET_KEY=<GENERATE_WITH_secrets.token_urlsafe_32>
